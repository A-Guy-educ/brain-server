# Brain Agent Configuration

# Required
ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional: Context+ (default: http://127.0.0.1:4097)
BRAIN_CONTEXTPLUS_URL=http://127.0.0.1:4097

# Brain Agent port (default: 4099)
BRAIN_PORT=4099

# Claude model (default: claude-opus-4-6)
BRAIN_MODEL=claude-opus-4-6

# Timeouts (in milliseconds)
BRAIN_CLAUDE_TIMEOUT_MS=60000
BRAIN_CONTEXTPLUS_TIMEOUT_MS=30000

# OB1 Integration (for user context from Supabase)
BRAIN_OB1_ENABLED=true
BRAIN_OB1_SUPABASE_URL=https://jmdccivoxtiumrpsujwg.supabase.co
BRAIN_OB1_SUPABASE_KEY=sb_publishable_HM54ruiE3qcxGwBkUx2xyw_MBLYOW6r
BRAIN_OB1_MATCH_THRESHOLD=0.7
BRAIN_OB1_MATCH_COUNT=5
