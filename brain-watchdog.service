[Unit]
Description=Brain Server Watchdog - Auto-restarts brain if unhealthy
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
ExecStart=/opt/brain-server/watchdog.sh
Restart=always
RestartSec=10
User=root
StandardOutput=append:/opt/brain-server/watchdog.log
StandardError=append:/opt/brain-server/watchdog.log

[Install]
WantedBy=multi-user.target
