# Brain Server Environment Variables
# Copy to .env.local and fill in values

# ===========================================
# BRAIN SERVER (VPS)
# ===========================================

# Brain server SSE endpoint (Tailscale private IP)
# Use this for local development
BRAIN_SERVER_URL=http://100.66.248.120:4097/sse

# Fallback: Public IP (if Tailscale is down)
# BRAIN_SERVER_URL=http://184.174.39.227:4097/sse

# ===========================================
# VPS CONNECTION (for reference)
# ===========================================

# SSH: root@184.174.39.227
# Tailscale VPS: 100.66.248.120
# Tailscale Mac: 100.117.15.74

# ===========================================
# DOCKER CONTAINERS (on VPS)
# ===========================================

# Brain MCP Server
BRAIN_CONTAINER=brain-server-brain-1

# Ollama (embedding model)
OLLAMA_CONTAINER=brain-server-ollama-1

# Webhook receiver
WEBHOOK_CONTAINER=brain-server-webhook-1

# ===========================================
# PORTS (for reference)
# ===========================================

# Brain SSE: 4097
# Ollama API: 11434
# Webhook: 9000

# ===========================================
# VPS MANAGEMENT COMMANDS
# ===========================================

# SSH to VPS
# ssh root@184.174.39.227

# Check containers
# ssh root@184.174.39.227 "docker ps | grep brain"

# Restart brain
# ssh root@184.174.39.227 "docker restart brain-server-brain-1"

# Watch watchdog logs
# ssh root@184.174.39.227 "tail -f /opt/brain-server/watchdog.log"

# Check watchdog status
# ssh root@184.174.39.227 "systemctl status brain-watchdog"
